# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Banco de dados ───────────────────────────────────────────────────────────
# Opção 1: Connection string (Railway/Supabase — tem prioridade sobre as vars abaixo)
DATABASE_URL=

# Opção 2: Variáveis individuais (desenvolvimento local sem Docker)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=db_VestWeb
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# ─── Autenticação ─────────────────────────────────────────────────────────────
JWT_SECRET=gere_uma_chave_forte_aqui
JWT_EXPIRES_IN=7d
# Generate a strong secret (64 random bytes in hex):
# npm run jwt:generate-secret

STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

CLIENT_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Em produção: URL do frontend na Vercel (sem barra final)
# Múltiplas origens separadas por vírgula
CLIENT_URL=http://localhost:5173,http://localhost:4173

# ─── URLs públicas ────────────────────────────────────────────────────────────
# Usadas nos links de pagamento do Stripe
CLIENT_URL_PUBLIC=http://localhost:5173
SERVER_URL=http://localhost:3001

# ─── Email (Nodemailer + Gmail) ───────────────────────────────────────────────
# Use senha de app: https://myaccount.google.com/apppasswords
EMAIL_USER=seuemail@gmail.com
EMAIL_PASS=sua_senha_de_app
EMAIL_TO=seuemail@gmail.com

# Optional integrations
ANTHROPIC_API_KEY=replace_me

# Rate limiting
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_PAYMENT_WINDOW_MS=900000
RATE_LIMIT_PAYMENT_MAX=5

# Auth cookie
AUTH_COOKIE_NAME=vestweb_token
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_MAX_AGE_MS=604800000

# PostgreSQL pool
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Health check
HEALTH_DB_TIMEOUT_MS=2000

# API versioning
API_VERSION=v1

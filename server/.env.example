PORT=3001
LOG_LEVEL=info

DB_HOST=localhost
DB_PORT=5432
DB_NAME=db_VestWeb
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui
# Runtime DB user (least privilege)
# When set, the app uses DB_RUNTIME_* instead of DB_USER/DB_PASSWORD.
DB_RUNTIME_USER=vestweb_app
DB_RUNTIME_PASSWORD=troque_por_uma_senha_forte

# Admin DB user (only for maintenance scripts, ex: db:provision-runtime-user)
DB_ADMIN_HOST=localhost
DB_ADMIN_PORT=5432
DB_ADMIN_NAME=db_VestWeb
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=sua_senha_admin_aqui

JWT_SECRET=cole_aqui_um_secret_forte_gerado_com_npm_run_jwt_generate_secret
JWT_EXPIRES_IN=7d
# Generate a strong secret (64 random bytes in hex):
# npm run jwt:generate-secret

STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

CLIENT_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Email (Nodemailer + Gmail)
# Use senha de app: https://myaccount.google.com/apppasswords
EMAIL_USER=seuemail@gmail.com
EMAIL_PASS=sua_senha_de_app
EMAIL_TO=seuemail@gmail.com

# Optional integrations
ANTHROPIC_API_KEY=replace_me

# Rate limiting
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_PAYMENT_WINDOW_MS=900000
RATE_LIMIT_PAYMENT_MAX=5

# Auth cookie
AUTH_COOKIE_NAME=vestweb_token
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_MAX_AGE_MS=604800000

# PostgreSQL pool
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Health check
HEALTH_DB_TIMEOUT_MS=2000

# API versioning
API_VERSION=v1

{
  "name": "VestWeb-server",
  "version": "1.0.0",
  "type": "module",
  "main": "app.js",
  "scripts": {
    "dev": "nodemon app.js",
    "start": "node app.js",
    "seed": "node src/db/seed.js",
    "seed:vestibulares": "node src/db/seedVestibulares.js",
    "import:questions": "for i in {2009..2020}; do node src/db/importQuestions.js data/raw/enem_$i.json; done",
    "classify": "node scripts/classify.js",
    "normalize": "node scripts/normalize-all.js",
    "clear:questions": "node scripts/clear-questions.js",
    "migrate": "node scripts/migrate-add-columns.js",
    "migrate:teacher": "node scripts/migrate-teacher-columns.js",
    "seed:sample-simulations": "node scripts/create-sample-simulations.js",
    "import": "node scripts/import.js",
    "import:all": "node scripts/import-all.js",
    "db:provision-runtime-user": "node scripts/provision-runtime-db-user.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "jwt:generate-secret": "node scripts/generate-jwt-secret.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dompurify": "^3.4.1",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsdom": "^22.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.13",
    "pg": "^8.11.5",
    "pg-hstore": "^2.3.4",
    "pino": "^10.3.1",
    "sequelize": "^6.37.3",
    "stripe": "^16.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@prisma/client": "^5.22.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "tsx": "^4.21.0"
  }
}
